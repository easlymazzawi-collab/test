# =============================================
#  Telegram Media Thumbnail Bot — Configuration
# =============================================

# --- Bot Token (from @BotFather) ---
BOT_TOKEN=123456789:AABBCCDDEEFFaabbccddeeff

# --- Pyrogram user-account credentials (from my.telegram.org) ---
# Required to crawl existing messages in the source topic
API_ID=12345678
API_HASH=abcdef1234567890abcdef1234567890

# --- Phone number linked to the Pyrogram session ---
PHONE_NUMBER=+84901234567

# --- Source chat (supergroup with forum topics enabled) ---
# Use the numeric ID (e.g. -1001234567890) or username
SOURCE_CHAT_ID=-1001234567890

# --- Thread/topic ID inside the source supergroup ---
# Open the topic in Telegram Web and read the ?thread= value
SOURCE_TOPIC_ID=123

# --- Destination chat where the bot posts thumbnails ---
# Can be a channel, group, or the same supergroup
DEST_CHAT_ID=-1001987654321

# --- Optional: destination topic thread ID (leave blank for no thread) ---
DEST_TOPIC_ID=

# --- SQLite database path ---
DB_PATH=data/bot.db

# --- Delay between publishing messages (seconds, to avoid flood-wait) ---
PUBLISH_DELAY=1.5

# --- Session name for Pyrogram ---
SESSION_NAME=media_crawler
