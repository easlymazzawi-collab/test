# =============================================
#  Telegram Topic Clone Bot — Configuration
# =============================================

# --- Bot Token (from @BotFather) ---
BOT_TOKEN=123456789:AABBCCDDEEFFaabbccddeeff

# --- Pyrogram user-account credentials (from my.telegram.org) ---
API_ID=12345678
API_HASH=abcdef1234567890abcdef1234567890
PHONE_NUMBER=+84901234567

# --- Source supergroup (must have Topics/Forum enabled) ---
SOURCE_CHAT_ID=-1001234567890

# --- SOURCE_TOPIC_ID ---
# • Set to a number  →  clone ONLY that one topic  (single-topic mode)
# • Leave empty      →  clone ALL topics            (all-topics mode)
SOURCE_TOPIC_ID=

# --- Destination chat (channel, group, or same supergroup) ---
# The bot must be admin here with "Manage Topics" permission
DEST_CHAT_ID=-1001987654321

# --- DEST_TOPIC_ID (only used in single-topic mode) ---
# Leave empty to post without a thread, or fill if dest is also a forum group
DEST_TOPIC_ID=

# --- Performance ---
# Delay between messages (seconds) — increase if you hit Telegram flood limits
PUBLISH_DELAY=1.5

# --- Storage ---
DB_PATH=data/bot.db
SESSION_NAME=media_crawler
